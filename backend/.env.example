# Copy this file to .env and fill in your real values.
# Never commit your real .env file — it contains secrets.

# Port the backend listens on
PORT=5000

# Which origin(s) are allowed to call this API.
# Use "*" for local testing; lock this down to your real domain in production.
# Example: ALLOWED_ORIGIN=https://yourdomain.com
ALLOWED_ORIGIN=*

# ---- Meta WhatsApp Cloud API ----
# From developers.facebook.com -> Your App -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_test_or_production_phone_number_id
WHATSAPP_API_VERSION=v19.0

# The number that should RECEIVE the inquiry notifications (yours),
# in international format with no "+", spaces, or leading zeros.
# Example: 15551234567
OWNER_WHATSAPP_NUMBER=8500352030

# Set to "true" once you're using an approved message template in production.
# Leave "false" for local testing with free-form text to a verified test number.
WHATSAPP_USE_TEMPLATE=false
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANG=en_US
